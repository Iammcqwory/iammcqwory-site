---
import "../styles/global.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>IAMMCQWORY | AI Systems for African Founders</title>
    <meta
      name="description"
      content="Nairobi-based founder, filmmaker, and AI strategist building operating systems, media brands, and creative ventures for African founders going global."
    />
    <meta property="og:title" content="IAMMCQWORY" />
    <meta
      property="og:description"
      content="Founder. Filmmaker. AI Strategist. Nairobi-based, African-founder-building-globally."
    />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0a0a0a" />
    <link
      rel="icon"
      href='data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64"><rect width="64" height="64" fill="%230a0a0a"/><text x="9" y="39" fill="%23f5f2ec" font-family="Arial" font-size="18" font-weight="900">MQ</text></svg>'
    />
  </head>
  <body>
    <div class="site">
      <nav class="nav" aria-label="Primary navigation">
        <a class="nav-logo" href="#">IAMMCQWORY</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="navLinks">
          <span></span>
          <span></span>
        </button>
        <ul class="nav-links" id="navLinks">
          <li><a href="#work">Work</a></li>
          <li><a href="#ventures">Ventures</a></li>
          <li><a href="#labs">Waziri Labs</a></li>
          <li><a href="#creative">Creative</a></li>
        </ul>
        <a class="nav-cta" href="#contact">Work With Me</a>
      </nav>

      <main>
        <section class="hero reveal" id="work">
          <div class="hero-left">
            <div class="hero-eyebrow">Nairobi-based / African-founder-building-globally</div>
            <h1 class="hero-title">
              Founder.<br />
              Filmmaker.<br />
              <em>AI Strategist.</em>
            </h1>
            <p class="hero-desc">
              I build AI-powered operating infrastructure, media brands, and creative systems for
              African founders moving from Nairobi to the world. No big teams. No wasted capital.
              Just leverage.
            </p>
            <div class="hero-actions">
              <a class="btn-primary" href="#contact">Book a Strategy Call</a>
              <a class="btn-secondary" href="#selected-work">
                View Case Studies
                <svg class="arrow-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 12h14"></path>
                  <path d="m13 6 6 6-6 6"></path>
                </svg>
              </a>
            </div>

            <div class="stats" aria-label="Founder statistics">
              <div class="stat">
                <div class="stat-num">12+</div>
                <div class="stat-label">Ventures Built</div>
              </div>
              <div class="stat">
                <div class="stat-num">6</div>
                <div class="stat-label">Industries</div>
              </div>
              <div class="stat">
                <div class="stat-num">NBI</div>
                <div class="stat-label">Based in Nairobi</div>
              </div>
              <div class="stat">
                <div class="stat-num">AI</div>
                <div class="stat-label">Native Operator</div>
              </div>
            </div>
          </div>

          <div class="hero-right">
            <div class="hero-card">
              <div class="card-label">Currently Deploying</div>
              <div class="card-title">Waziri Collective Labs</div>
              <ul class="service-list">
                <li>We don't pitch AI transformation.</li>
                <li>We find the thing breaking your operation and fix it.</li>
                <li>Business Systems Audits for founders and SMEs</li>
                <li>Workflow automation, agents, and data pipelines</li>
              </ul>
              <div class="card-geo">Nairobi, Kenya → Pan-African</div>
              <div class="deco-text">BIG</div>
            </div>
          </div>
        </section>

        <div class="ticker" aria-label="Selected ventures ticker">
          <div class="ticker-inner">
            <span class="ticker-item">The Nairobi Post <span>■</span></span>
            <span class="ticker-item">Sounds from Kenya <span>■</span></span>
            <span class="ticker-item">Studio Sitini <span>■</span></span>
            <span class="ticker-item">Waziri Collective Labs <span>■</span></span>
            <span class="ticker-item">Luku Safi <span>■</span></span>
            <span class="ticker-item">Mamabora <span>■</span></span>
            <span class="ticker-item">Health Tech <span>■</span></span>
            <span class="ticker-item">Vijanabora <span>■</span></span>
            <span class="ticker-item">The Nairobi Post <span>■</span></span>
            <span class="ticker-item">Sounds from Kenya <span>■</span></span>
            <span class="ticker-item">Studio Sitini <span>■</span></span>
            <span class="ticker-item">Waziri Collective Labs <span>■</span></span>
            <span class="ticker-item">Luku Safi <span>■</span></span>
            <span class="ticker-item">Mamabora <span>■</span></span>
            <span class="ticker-item">Fashion <span>■</span></span>
            <span class="ticker-item">Vijanabora <span>■</span></span>
          </div>
        </div>

        <section class="ventures reveal" id="ventures">
          <div class="ventures-label">Bora International Group Portfolio</div>
          <p class="portfolio-line">Media, health tech, fintech, fashion, youth advocacy.</p>
          <div class="ventures-grid" id="venturesGrid" role="tablist" aria-label="Portfolio companies">
            <button class="venture-pill active" type="button" role="tab" aria-selected="true" data-venture="waziri">
              Waziri Labs
            </button>
            <button class="venture-pill" type="button" role="tab" aria-selected="false" data-venture="nairobi">
              Nairobi Post
            </button>
            <button class="venture-pill" type="button" role="tab" aria-selected="false" data-venture="sounds">
              Sounds from KE
            </button>
            <button class="venture-pill" type="button" role="tab" aria-selected="false" data-venture="sitini">
              Studio Sitini
            </button>
            <button class="venture-pill" type="button" role="tab" aria-selected="false" data-venture="mamabora">
              Mamabora
            </button>
            <button class="venture-pill" type="button" role="tab" aria-selected="false" data-venture="vijanabora">
              Vijanabora
            </button>
          </div>
          <article class="venture-detail" id="ventureDetail" aria-live="polite"></article>
        </section>

        <section class="section reveal" id="labs">
          <div class="section-header">
            <h2 class="section-title">What I build</h2>
            <span class="section-num">01 / 04</span>
          </div>
          <div class="services-grid">
            <article class="service-card">
              <div class="service-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <rect x="7" y="7" width="10" height="10" rx="2"></rect>
                  <path d="M4 10h3M4 14h3M17 10h3M17 14h3M10 4v3M14 4v3M10 17v3M14 17v3"></path>
                </svg>
              </div>
              <div class="service-name">Business Systems Audit</div>
              <p class="service-desc">
                We find the thing breaking your operation, map the bottleneck, and turn it into a
                practical automation roadmap.
              </p>
            </article>
            <article class="service-card">
              <div class="service-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M4 8h3l2-2h6l2 2h3v10H4z"></path>
                  <circle cx="12" cy="13" r="3"></circle>
                </svg>
              </div>
              <div class="service-name">AI Workflow Automation</div>
              <p class="service-desc">
                Lightweight agents, API integrations, content ops, and repeatable delivery systems
                for founders and SMEs.
              </p>
            </article>
            <article class="service-card">
              <div class="service-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M4 18h16"></path>
                  <path d="m6 15 4-4 3 3 5-7"></path>
                  <path d="M16 7h2v2"></path>
                </svg>
              </div>
              <div class="service-name">Creative Production Systems</div>
              <p class="service-desc">
                Photography, cinematography, campaign assets, short-form repurposing, and media
                pipelines that compound.
              </p>
            </article>
            <article class="service-card">
              <div class="service-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M4 5h16v14H4z"></path>
                  <path d="M8 9h8M8 13h5"></path>
                  <path d="M17 17 20 20"></path>
                </svg>
              </div>
              <div class="service-name">Data &amp; Decision Intelligence</div>
              <p class="service-desc">
                Dashboards, data pipelines, and founder-facing decision tools that make the next
                move obvious.
              </p>
            </article>
          </div>
        </section>

        <section class="selected-work reveal" id="selected-work">
          <div class="section-header">
            <h2 class="section-title">Selected work</h2>
            <span class="section-num">02 / 04</span>
          </div>
          <div class="case-grid">
            <article class="case-card">
              <span class="case-index">01</span>
              <h3>Waziri Collective Labs</h3>
              <p>AI strategy and automation consultancy for founders and SMEs. We don't pitch AI transformation. We find the thing breaking your operation and fix it.</p>
              <dl>
                <div><dt>Role</dt><dd>Founder / Systems Architect</dd></div>
                <div><dt>Signal</dt><dd>Business Systems Audit, agents, automation</dd></div>
              </dl>
            </article>
            <article class="case-card">
              <span class="case-index">02</span>
              <h3>Mamabora</h3>
              <p>AI-powered parenting companion for mothers and caregivers, built around expert guidance, milestone tracking, and instant support.</p>
              <dl>
                <div><dt>Role</dt><dd>Founder / Product Builder</dd></div>
                <div><dt>Signal</dt><dd>Parenting, health tech, caregiver support</dd></div>
              </dl>
            </article>
            <article class="case-card">
              <span class="case-index">03</span>
              <h3>Vijanabora</h3>
              <p>Mental health advocacy for youth in Kenya and other developing places in Africa.</p>
              <dl>
                <div><dt>Role</dt><dd>Impact Venture Builder</dd></div>
                <div><dt>Signal</dt><dd>Youth advocacy, mental health, Kenya</dd></div>
              </dl>
            </article>
          </div>
        </section>

        <section class="operator reveal">
          <div>
            <span class="operator-kicker">Operator Profile</span>
            <h2>Nairobi-based, building systems and stories for African founders going global.</h2>
          </div>
          <p>
            IAMMCQWORY is the studio practice of Makori Brian: founder, filmmaker, AI strategist,
            and systems builder. The operating context is Bora International Group: media, health
            tech, fintech, fashion, youth advocacy.
          </p>
        </section>

        <section class="writing reveal" id="creative">
          <div class="section-header">
            <h2 class="section-title">Creative work</h2>
            <span class="section-num">03 / 04</span>
          </div>
          <div class="writing-list">
            <a href="https://iammcqwory.mypixieset.com" target="_blank" rel="noopener">
              <span>Pixieset</span>
              <strong>Photography for weddings, travel, events, and production-led stories.</strong>
            </a>
            <a href="https://vimeo.com/iammcqwory" target="_blank" rel="noopener">
              <span>Vimeo</span>
              <strong>Cinematography, motion, and visual direction from Nairobi outward.</strong>
            </a>
            <a href="https://www.behance.net/iammcqwory" target="_blank" rel="noopener">
              <span>Behance</span>
              <strong>Portfolio-grade creative work across film, brand, and production systems.</strong>
            </a>
            <a href="https://youtu.be/sSWlbBoNfpE?si=lNQvM-TrdPZ0GycX" target="_blank" rel="noopener">
              <span>Media</span>
              <strong>Talks and video work embedded inside the creative practice, not as a separate content promise.</strong>
            </a>
          </div>
        </section>

        <section class="contact reveal" id="contact">
          <div class="contact-copy">
            <span class="operator-kicker">Strategy Call</span>
            <h2>Bring the bottleneck. Leave with the system map.</h2>
            <p>
              Best fit: founders, media operators, and creative businesses with a real workflow
              problem and enough momentum to operationalize the answer.
            </p>
          </div>
          <form class="contact-form" action="mailto:hello@iammcqwory.studio" method="post" enctype="text/plain">
            <label>
              Name
              <input name="name" type="text" autocomplete="name" />
            </label>
            <label>
              Email
              <input name="email" type="email" autocomplete="email" />
            </label>
            <label>
              What are we systemizing?
              <textarea name="brief" rows="4"></textarea>
            </label>
            <button class="btn-primary" type="submit">Send Brief</button>
          </form>
        </section>
      </main>

      <footer class="footer">
        <div class="footer-left">IAMMCQWORY © 2026</div>
        <div class="footer-right">Nairobi → Dubai → Global</div>
      </footer>
    </div>

    <script is:inline src="/site.js"></script>
  </body>
</html>
